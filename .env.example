# EternoMind Environment Configuration
# Copy this file to .env and fill in the required values

# ── App Settings ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Database ─────────────────────────────────────────────────────
# Local SQLite (default, works without setup)
DATABASE_URL=sqlite:///./eternomind.db
# Or PostgreSQL (requires separate DB setup)
# DATABASE_URL=postgresql://user:password@localhost:5432/eternomind

# ── Redis ────────────────────────────────────────────────────────
# For local development: Use Docker or install Redis
# Docker: docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB (Vector Store) ──────────────────────────────────────
# For local development: Use Docker or install ChromaDB
# Docker: docker run -d -p 8001:8000 chromadb/chroma:latest
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── LLM & AI Services ────────────────────────────────────────────
# Required: Groq API Key (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Required: Hindsight API Key (https://app.hindsight.so/settings)
HINDSIGHT_API_KEY=your_hindsight_api_key_here

# Optional: cascadeflow API Key (https://app.cascadeflow.ai/)
CASCADEFLOW_API_KEY=

# ── Model Configuration ──────────────────────────────────────────
# Available Groq models:
GROQ_LARGE_MODEL=llama-3.3-70b-versatile
GROQ_SMALL_MODEL=llama-3.1-8b-instant
# Expert model (optional, uses Mixtral)
GROQ_EXPERT_MODEL=mixtral-8x7b-32768

# ── CORS Configuration ───────────────────────────────────────────
# For local development:
CORS_ORIGINS=http://localhost:5173
# For production, use actual domain:
# CORS_ORIGINS=https://yourdomain.com
